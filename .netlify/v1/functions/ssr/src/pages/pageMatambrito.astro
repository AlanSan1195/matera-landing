---
import VisualDishPage from "@/layouts/VisualDishPage.astro";
import ArrowCurved from "@/components/icons/ArrowCurved.astro";

const matambre = {
  src: "/imagenes/carta/parrilla/granja/matambrito.webp",
  name: "Matambrito de cerdo",
  gramaje: "350gr / 12oz",
  price: "$450",
  visualDescription:
    "El matambrito es un corte de cerdo que proviene de la parte del pecho del animal.",
  title: "Visual del platillo matambrito de cerdo",
  description: "Visual del platillo matambrito de cerdo",
};
---

<VisualDishPage title={matambre.title} description={matambre.description}>
  <img
    slot="image"
    src="/imagenes/visuales/matambreVisual.webp"
    alt="imagen en alta calidad del Matambrito de cerdo"
    class="object-cover h-full w-full"
  />
  <div slot="annotations">
    <div class="absolute top-[125px] max-w-[220px] left-[100px]">
      <p class="caja-texto font-pages opacity-80 text-sm">
        {matambre.visualDescription}
      </p>
    </div>
    <div class="svg absolute top-[150px] left-[20px] rotate-[-80deg]">
      <ArrowCurved width={90} height={88} />
    </div>
    <div class="absolute top-[535px] max-w-[120px] left-[120px]">
      <p class="caja-texto2 font-pages opacity-80 text-sm">
        Pure de camote horneado al momento.
      </p>
    </div>
    <div class="svg2 absolute top-[480px] left-[200px] rotate-[100deg]">
      <ArrowCurved width={90} height={88} />
    </div>
  </div>
</VisualDishPage>
