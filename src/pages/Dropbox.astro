<script>
  // ---- Tabs principales (Manual / Platillos) ----
  document.querySelectorAll<HTMLButtonElement>("[data-tab-principal]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.tabPrincipal;
      if (!target) return;

      // Actualizar tabs
      document.querySelectorAll<HTMLButtonElement>("[data-tab-principal]").forEach((t) => t.classList.remove("activo"));
      btn.classList.add("activo");

      // Mostrar/ocultar paneles
      document.querySelectorAll<HTMLElement>(".panel-contenido").forEach((p) => p.classList.remove("panel-visible"));
      document.getElementById(`panel-${target}`)?.classList.add("panel-visible");
    });
  });

  // ---- Navegación de secciones del manual ----
  document.querySelectorAll<HTMLButtonElement>("[data-seccion-btn]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.seccionBtn;
      if (!target) return;

      // Actualizar botones
      document.querySelectorAll<HTMLButtonElement>("[data-seccion-btn]").forEach((b) => b.classList.remove("seccion-activa"));
      btn.classList.add("seccion-activa");

      // Mostrar/ocultar secciones
      document.querySelectorAll<HTMLElement>("[data-seccion]").forEach((s) => s.classList.remove("seccion-visible"));
      document.querySelector<HTMLElement>(`[data-seccion="${target}"]`)?.classList.add("seccion-visible");

      // Scroll suave al top
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  });
</script>

{esAdmin && (
  <script>
    // ---- Elementos del DOM ----
    const modal = document.getElementById("modal-overlay");
    const modalTitulo = document.getElementById("modal-titulo");
    const form = document.getElementById("form-platillo") as HTMLFormElement | null;
    const inputId = document.getElementById("input-id") as HTMLInputElement | null;
    const inputTitulo = document.getElementById("input-titulo") as HTMLInputElement | null;
    const inputDescripcion = document.getElementById("input-descripcion") as HTMLTextAreaElement | null;
    const inputGramaje = document.getElementById("input-gramaje") as HTMLInputElement | null;
    const inputImagen = document.getElementById("input-imagen") as HTMLInputElement | null;
    const previewImagen = document.getElementById("preview-imagen") as HTMLImageElement | null;
    const btnGuardarTexto = document.getElementById("btn-guardar-texto");
    const btnGuardarSpinner = document.getElementById("btn-guardar-spinner");
    const btnGuardar = document.getElementById("btn-guardar") as HTMLButtonElement | null;

    // ---- Helpers ----
    function abrirModal(titulo: string) {
      if (!modal || !modalTitulo) return;
      modalTitulo.textContent = titulo;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function cerrarModal() {
      if (!modal) return;
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
      form?.reset();
      if (inputId) inputId.value = "";
      if (previewImagen) {
        previewImagen.classList.add("hidden");
        previewImagen.src = "";
      }
    }

    function setLoading(loading: boolean) {
      if (btnGuardar) btnGuardar.disabled = loading;
      if (btnGuardarTexto) btnGuardarTexto.textContent = loading ? "Guardando..." : "Guardar";
      if (btnGuardarSpinner) {
        btnGuardarSpinner.classList.toggle("hidden", !loading);
      }
    }

    // ---- Subir imagen ----
    async function subirImagenArchivo(file: File): Promise<string | null> {
      const formData = new FormData();
      formData.append("file", file);

      const res = await fetch("/api/admin/upload", {
        method: "POST",
        body: formData,
      });

      if (!res.ok) return null;
      const data = await res.json();
      return data.url ?? null;
    }

    // ---- Preview de imagen ----
    inputImagen?.addEventListener("change", () => {
      const file = inputImagen.files?.[0];
      if (!file || !previewImagen) return;

      const reader = new FileReader();
      reader.onload = (e) => {
        previewImagen.src = e.target?.result as string;
        previewImagen.classList.remove("hidden");
      };
      reader.readAsDataURL(file);
    });

    // ---- Abrir modal: Agregar ----
    document.getElementById("btn-agregar")?.addEventListener("click", () => {
      abrirModal("Agregar platillo");
    });

    // ---- Abrir modal: Editar ----
    document.querySelectorAll(".btn-editar").forEach((btn) => {
      btn.addEventListener("click", () => {
        const el = btn as HTMLElement;
        if (inputId) inputId.value = el.dataset.id ?? "";
        if (inputTitulo) inputTitulo.value = el.dataset.titulo ?? "";
        if (inputDescripcion) inputDescripcion.value = el.dataset.descripcion ?? "";
        if (inputGramaje) inputGramaje.value = el.dataset.gramaje ?? "";

        // Mostrar imagen actual si existe
        const imagenActual = el.dataset.imagen;
        if (imagenActual && previewImagen) {
          previewImagen.src = imagenActual;
          previewImagen.classList.remove("hidden");
        }

        abrirModal("Editar platillo");
      });
    });

    // ---- Cerrar modal ----
    document.getElementById("btn-cerrar-modal")?.addEventListener("click", cerrarModal);
    document.getElementById("btn-cancelar")?.addEventListener("click", cerrarModal);
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) cerrarModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal?.classList.contains("hidden")) cerrarModal();
    });

    // ---- Submit: Crear o Actualizar ----
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      setLoading(true);

      try {
        const id = inputId?.value ?? "";
        const titulo = inputTitulo?.value ?? "";
        const descripcion = inputDescripcion?.value ?? "";
        const gramaje = inputGramaje?.value ?? "";

        // Subir imagen si hay un archivo seleccionado
        let imagen_url: string | null = null;
        const archivo = inputImagen?.files?.[0];
        if (archivo) {
          imagen_url = await subirImagenArchivo(archivo);
          if (!imagen_url) {
            alert("Error al subir la imagen. Intenta de nuevo.");
            setLoading(false);
            return;
          }
        }

        const body: Record<string, string | null> = { titulo, descripcion, gramaje };
        if (imagen_url) body.imagen_url = imagen_url;

        // Si hay id, es update; sino es create
        if (id) {
          body.id = id;
          const res = await fetch("/api/admin/platillos", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(body),
          });
          if (!res.ok) throw new Error("Error al actualizar");
        } else {
          const res = await fetch("/api/admin/platillos", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(body),
          });
          if (!res.ok) throw new Error("Error al crear");
        }

        cerrarModal();
        window.location.reload();
      } catch (err) {
        alert("Ocurrio un error. Revisa la consola.");
        console.error(err);
      } finally {
        setLoading(false);
      }
    });

    // ---- Eliminar ----
    document.querySelectorAll(".btn-eliminar").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const el = btn as HTMLElement;
        const id = el.dataset.id;
        const titulo = el.dataset.titulo ?? "este platillo";

        if (!confirm(`¿Seguro que quieres eliminar "${titulo}"?`)) return;

        try {
          const res = await fetch("/api/admin/platillos", {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id }),
          });

          if (!res.ok) throw new Error("Error al eliminar");
          window.location.reload();
        } catch (err) {
          alert("Error al eliminar el platillo.");
          console.error(err);
        }
      });
    });
  </script>
)}
