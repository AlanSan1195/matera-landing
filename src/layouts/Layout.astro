---
import LightsBackground from "@/components/LightsBackground.astro";

import "@fontsource-variable/lora";
import "@fontsource/permanent-marker";

export interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { title, description, lang = "es" } = Astro.props;

const SITE_URL = "https://www.lamatera.club";
const canonicalUrl = `${SITE_URL}${Astro.url.pathname}`;
const ogImageUrl = `${SITE_URL}/imagenes/preview.webp`;

const ogLocaleMap: Record<string, string> = {
  es: "es_ES",
  en: "en_US",
  ko: "ko_KR",
  zh: "zh_CN",
  ja: "ja_JP",
};
const ogLocale = ogLocaleMap[lang] ?? "es_ES";
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://accounts.dev" crossorigin />
    <link rel="dns-prefetch" href="https://accounts.dev" />
    <link rel="preload" href="/fuentes/Magical Night.woff2" as="font" type="font/woff2" crossorigin />
    <link
      rel="icon"
      type="image/webp"
      href="/imagenes/logo-cabecera.webp"
    />
    <link rel="apple-touch-icon" sizes="180x180" href="/imagenes/logo-cabecera.webp" />
    <link rel="canonical" href={canonicalUrl} />
    <meta
      name="description"
      content={description}
    />
    <meta name="google-site-verification" content="zuRgqcQ25AX8z3a-qvX5CG-Gfy_eYJSoUt_T7LDRQG4" />
    <meta name="keywords" content="comida,vino,restaurante,argentina,cava,servicio,chef,eventos,argentino,cortes,bife,lomo,vacio,entraña,asado,chorizo,lomito,rib eye,parrilla,facturacion" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="La Matera — Restaurante Argentino en Guadalajara" />
    <meta property="og:image" content={ogImageUrl} />
    <meta content="summary_large_image" name="twitter:card" />
    <meta name="twitter:site" content="@lamateragdl" />
    <meta name="twitter:creator" content="@AlanSan86780460" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <LightsBackground />
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --primary: #0e191a;
  }
  @font-face {
    font-family: "boldes";
    src: url("/fuentes/Magical\ Night.woff2");
    font-display: swap;
  }
  html,
  body {
    overflow-x: hidden;
  }
  html {
    font-family: "Lora Variable";
  }

  /* Tailwind Preflight ya aplica el reset universal (margin, padding, box-sizing) */
  video {
    mask-image: linear-gradient(grey 90%, transparent 100%);

  }
  [data-carrusel] {
      mask-image: linear-gradient(to bottom, transparent 1%, black 10%);
    }
  @media (min-width: 768px) {
    [data-carrusel] {
      mask-image: linear-gradient(to bottom, transparent 1%, black 10%);
    }
    #nosotros {
      mask-image: linear-gradient(black 98%, transparent 100%);
    }
  }

  .invisible {
    display: none;
  }

  /* efecto de REFELEJO para imagen de nostros */
  .nosotros-img {
    border-radius: 13px;

    object-fit: cover;
    background: hsl(10 80% 100%);
    -webkit-box-reflect: below 6px
      linear-gradient(transparent 0 80%, hsl(0 0% 100% / 0.6) 100%);
  }
  .nosotros-img2 {
    border-radius: 13px;

    object-fit: cover;
    background: hsl(10 80% 100%);
    -webkit-box-reflect: below 6px
      linear-gradient(transparent 0 80%, hsla(0, 0%, 100%, 0.242) 100%);
  }

  .image-drop-shadow-empanadas {
    height: 6rem; /* Altura fija de 12rem */
    width: 6rem; /* Ancho fijo de 12rem */
    object-fit: cover; /* Asegura que la imagen cubra todo el espacio asignado sin deformarse */
    /* Margen superior de 0.5rem */
    margin-right: 0.5rem; /* Margen derecho de 0.5rem */
    margin-left: auto; /* Margen izquierdo automático para centrar horizontalmente */
    filter: drop-shadow(
      2px 4px 6px black
    ); /* Sombra con desplazamiento horizontal de 2px, vertical de 4px y difuminado de 6px */
  }
  .image-drop-shadow {
    height: 8rem; /* Altura fija de 12rem */
    width: 8rem; /* Ancho fijo de 12rem */
    object-fit: cover; /* Asegura que la imagen cubra todo el espacio asignado sin deformarse */
    /* Margen superior de 0.5rem */
    margin-right: 0.5rem; /* Margen derecho de 0.5rem */
    margin-bottom: 0.9rem;
    margin-left: auto; /* Margen izquierdo automático para centrar horizontalmente */
    filter: drop-shadow(
      2px 4px 6px black
    ); /* Sombra con desplazamiento horizontal de 2px, vertical de 4px y difuminado de 6px */
  }
  .simple-radial {
    background: radial-gradient(rgb(80, 82, 78), rgb(0, 0, 0));
  }

</style>
