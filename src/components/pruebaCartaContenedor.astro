---
import CutCard from "./CutCard.astro";
import CardsComponent from "./CardsComponent.astro";
import {
  empanadas,
  pizzas,
  entradas,
  ensaladas,
  cocina,
  postres,
  campoData,
  campoMapaData,
  marData,
  granjaData,
  filetes,
  vacios,
  entranas,
  asados,
  bifes,
