  ---
import ParrillaSection from "@/components/menu/ParrillaSection.astro";
import CardsComponent from "@/components/CardsComponent.astro";
import {
  empanadas,
  pizzas,
  entradas,
  ensaladas,
  cocina,
  postres,
  campoData,
  campoMapaData,
} from "@/data/menuData";
import { useTranslations, getLangFromUrl, type Lang } from "@/i18n/utils";

export interface Props {
  id: string;
  lang?: Lang;
}

const { id, lang: langProp } = Astro.props;
const lang: Lang = langProp ?? (getLangFromUrl(Astro.url) as Lang);
const t = useTranslations(lang);
const tc = t.carta;

// Helper: devuelve la traducción del nombre de un plato (vacío en español)
function platNombre(nombre: string): string | undefined {
  const plato = tc.platos[nombre as keyof typeof tc.platos];
  if (!plato) return undefined;
  const n = (plato as { nombre: string }).nombre;
  return n && lang !== "es" ? n : undefined;
}

// Helper: devuelve la traducción de la descripción (vacío en español)
function platDescripcion(nombre: string): string | undefined {
  const plato = tc.platos[nombre as keyof typeof tc.platos];
  if (!plato) return undefined;
  const d = (plato as { descripcion: string }).descripcion;
  return d && lang !== "es" ? d : undefined;
}

const categories = [
  { id: "Empanadas", name: tc.tabs.empanadas, items: empanadas },
  { id: "Entradas",  name: tc.tabs.entradas,  items: entradas  },
  { id: "Ensaladas", name: tc.tabs.ensaladas, items: ensaladas },
  { id: "Pizzas",    name: tc.tabs.pizzas,    items: pizzas    },
  { id: "Cocina",    name: tc.tabs.cocina,    items: cocina    },
  { id: "Postres",   name: tc.tabs.postres,   items: postres   },
];
---

<section class="landing-section h-full w-screen overflow-hidden" id={id}>
  <nav id="navegacion-carta" class="flex flex-col items-center">

    <!-- Header -->
    <header class="text-center mt-12 mb-6 text-white">
      <p class="text-5xl md:text-7xl font-boldes">{tc.heading}</p>
      <h3 class="text-3xl md:text-5xl font-boldes opacity-55">
        {tc.subheading}
      </h3>
    </header>

    <!-- Tabs de categorías -->
    <div class="flex justify-center flex-wrap gap-x-6 gap-y-2 px-4 opacity-90">
      {
        categories.map((cat) => (
          <button
            id={`btn${cat.id}`}
            class="menu-tab hover:cursor-pointer font-bold text-2xl md:text-3xl text-white transition-colors duration-200"
          >
            {cat.name}
          </button>
        ))
      }
      <a
        href="https://cavamatera.online"
        aria-label="cavamatera"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:cursor-pointer font-boldes text-2xl md:text-3xl text-white"
      >
        {tc.tabs.vinos}
      </a>
      <button
        id="btnParrilla"
        class="menu-tab hover:cursor-pointer font-boldes text-2xl md:text-3xl text-white transition-colors duration-200"
      >
        {tc.tabs.parrilla}
      </button>
    </div>

    <!-- Paneles de categorías -->
    {
      categories.map((cat) => (
        <div
          id={`div${cat.id}`}
          class="menu-panel hidden w-full grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 p-6 mb-16"
        >
          {cat.items.map((item) => (
            <CardsComponent
              src={item.src}
              name={item.name}
              description={item.description}
              price={item.price}
              nameTranslation={platNombre(item.name)}
              descripTranslation={platDescripcion(item.name)}
            />
          ))}
        </div>
      ))
    }

    <!-- Panel Parrilla -->
    <div id="divParrillaPanel" class="menu-panel hidden w-full">
      <ParrillaSection lang={lang} />
    </div>

  </nav>
</section>

<script define:vars={{ campoData, campoMapaData }}>
  document.addEventListener("DOMContentLoaded", () => {
    // ── Tabs del menú principal ──
    const tabIds = [
      "Empanadas", "Entradas", "Ensaladas", "Pizzas", "Cocina", "Postres", "Parrilla",
    ];

    const pairs = tabIds
      .map((name) => ({
        btn: document.getElementById(`btn${name}`),
        panel: document.getElementById(name === "Parrilla" ? "divParrillaPanel" : `div${name}`),
        isGrid: name !== "Parrilla",
      }))
      .filter((p) => p.btn && p.panel);

    function hideAll() {
      pairs.forEach(({ btn, panel }) => {
        btn.classList.remove("text-red-600");
        btn.classList.add("text-white");
        panel.classList.add("hidden");
        panel.classList.remove("grid", "block");
      });
    }

    pairs.forEach(({ btn, panel, isGrid }) => {
      btn.addEventListener("click", () => {
        const alreadyOpen = !panel.classList.contains("hidden");
        hideAll();
        if (!alreadyOpen) {
          btn.classList.remove("text-white");
          btn.classList.add("text-red-600");
          panel.classList.remove("hidden");
          panel.classList.add(isGrid ? "grid" : "block");
        }
      });
    });

    // Open Entradas by default
    const entradasPair = pairs.find((p) => p.btn?.id === "btnEntradas");
    if (entradasPair) {
      entradasPair.btn.classList.remove("text-white");
      entradasPair.btn.classList.add("text-red-600");
      entradasPair.panel.classList.remove("hidden");
      entradasPair.panel.classList.add("grid");
    }

    // ── Parrilla sub-nav ──
    const botonCampo  = document.getElementById("botonCampo");
    const botonMar    = document.getElementById("botonMar");
    const botonGranja = document.getElementById("botonGranja");
    const divCampo    = document.getElementById("divCampo");
    const divMar      = document.getElementById("divMar");
    const divGranja   = document.getElementById("divGranja");

    if (!botonCampo || !botonMar || !botonGranja || !divCampo || !divMar || !divGranja) return;

    const corteDivIds = ["divFiletes", "divVacios", "divEntrañas", "divAsados", "divRibEye"];
    const divsCortes = corteDivIds.map((id) => document.getElementById(id)).filter(Boolean);

    // Hide all cut-detail cards initially
    divsCortes.forEach((div) => div.classList.add("hidden"));

    const parrillaSubDivs = [divCampo, divMar, divGranja];
    const parrillaSubBtns = [botonCampo, botonMar, botonGranja];

    function hideAllParrilla() {
      parrillaSubDivs.forEach((div) => {
        div.classList.add("hidden");
        div.classList.remove("grid");
      });
      divsCortes.forEach((div) => {
        div.classList.add("hidden");
        div.classList.remove("grid");
      });
    }

    function showParrillaDiv(div) {
      div.classList.remove("hidden");
      div.classList.add("grid");
    }

    function setActiveParrillaBtn(activeBtn) {
      parrillaSubBtns.forEach((b) => {
        b.classList.remove("text-red-600");
        b.classList.add("text-white");
      });
      activeBtn.classList.remove("text-white");
      activeBtn.classList.add("text-red-600");
    }

    botonCampo.addEventListener("click", () => {
      hideAllParrilla();
      showParrillaDiv(divCampo);
      setActiveParrillaBtn(botonCampo);
    });
    botonMar.addEventListener("click", () => {
      hideAllParrilla();
      showParrillaDiv(divMar);
      setActiveParrillaBtn(botonMar);
    });
    botonGranja.addEventListener("click", () => {
      hideAllParrilla();
      showParrillaDiv(divGranja);
      setActiveParrillaBtn(botonGranja);
    });

    // Click on a campo cut image → show its CutCard
    campoMapaData.forEach((item, index) => {
      const img = document.getElementById(item.src);
      if (!img) return;
      img.addEventListener("click", () => {
        const divCarne = divsCortes[index];
        if (!divCarne) return;

        const isHidden = divCarne.classList.contains("hidden");
        // Toggle: if open, close and show map; if closed, open and hide map
        if (isHidden) {
          divCarne.classList.remove("hidden");
          divCarne.classList.add("grid");
          divCampo.classList.add("hidden");
          divCampo.classList.remove("grid");
        } else {
          divCarne.classList.add("hidden");
          divCarne.classList.remove("grid");
          // If no other corte is open, bring back the map
          const anyOpen = divsCortes.some((d) => !d.classList.contains("hidden"));
          if (!anyOpen) {
            divCampo.classList.remove("hidden");
            divCampo.classList.add("grid");
          }
        }
      });
    });

    // Close buttons inside CutCards → return to campo map
    document.querySelectorAll("#divParrilla #botonCerrar").forEach((btn) => {
      btn.addEventListener("click", () => {
        divsCortes.forEach((div) => {
          div.classList.add("hidden");
          div.classList.remove("grid");
        });
        divCampo.classList.remove("hidden");
        divCampo.classList.add("grid");
      });
    });
  });
</script>
