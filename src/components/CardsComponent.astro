---
const { src, name, description, price, nameTranslation, descripTranslation } = Astro.props;
---

<div class="relative flex flex-col items-center gap-y-1 transition-all duration-500 border-b h-[180px] w-full border-red-800/60 rounded-2xl group p-3 before:w-full before:h-full before:rounded-2xl before:backdrop-blur-sm before:z-10 before:absolute overflow-hidden">
  <div
    class="relative shrink-0 opacity-10 w-max z-50 blur-sm transition-all duration-500 group-hover:blur-none group-hover:-translate-y-1 translate-y-4 group-hover:opacity-100"
  >
    <img
      class="h-20 w-20 object-cover mx-auto drop-shadow-[2px_4px_6px_black]"
      src={src}
      alt={name}
      loading="lazy"
      decoding="async"
      width="80"
      height="80"
    />
  </div>
  <p
    class="text-center font-boldes text-sm leading-tight text-white/55 transition-all duration-500 z-[60] group-hover:text-white/85 shrink-0"
  >
    {name}
  </p>
  {nameTranslation && (
    <p class="text-center text-[10px] leading-tight text-white/35 italic z-[60] transition-all duration-500 group-hover:text-white/60 shrink-0">
      {nameTranslation}
    </p>
  )}
  <p
    class="text-center text-[10px] leading-snug text-white/35 transition-all duration-500 z-[60] group-hover:text-white/75 line-clamp-2 shrink-0"
  >
    {descripTranslation || description}
  </p>
  <p
    class="text-center text-xs font-boldes text-white/65 transition-all duration-500 z-[60] group-hover:translate-y-1 group-hover:text-white/85 shrink-0 mt-auto"
  >
    {price}
  </p>
</div>
