---
import type { CampoItem, CorteTalla, BifeItem } from "@/data/menuData";

export interface Props {
  id: string;
  titulo: string;
  info: CampoItem;
  items: CorteTalla[] | BifeItem[];
  cols?: number;
  esBife?: boolean;
  descripcionTraducida?: string;
}

const { id, titulo, info, items, cols = 2, esBife = false, descripcionTraducida } = Astro.props;
---

<div
  id={id}
  class="flex justify-center mx-auto border-[2px] border-[#B56C09]/60 bg-black/70 backdrop-blur-sm text-sm rounded-xl text-white content-center m-2 md:rounded-xl md:border-none md:w-screen md:bg-black/30"
>
  <div class="flex items-center mx-6 mt-3 md:justify-between md:w-screen md:px-8">
    <p class="opacity-0 flex">........</p>
    <p class="text-white font-boldes text-xl flex w-full justify-center opacity-80 md:text-red-800">
      {titulo}
    </p>
    <button
      id="botonCerrar"
      type="button"
      class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-[#B56C09] dark:hover:text-white"
      data-modal-hide="top-left-modal"
      aria-label={`Cerrar ${titulo}`}
    >
      <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"></path>
      </svg>
    </button>
  </div>

  <div class="flex flex-col justify-center items-center">
    <img class="size-28 mx-auto" src={info.src} alt={info.name} />
    <p class="text-sm mb-4 top-0 w-[280px] text-center text-wrap opacity-80">
      {descripcionTraducida ?? info.description}
    </p>
  </div>

  <div class={`grid grid-cols-${cols} m-4 justify-center gap-8 md:gap-2 text-center`}>
    {
      esBife
        ? (items as BifeItem[]).map((bife) => (
            <div class="justify-between flex flex-col text-sm leading-none items-center text-center gap-y-1">
              <p class="font-boldes mb-2">{bife.name}</p>
              <div class="flex gap-2">
                <p class="font-bold text-xs text-red-600/80">{bife.quality}</p>
              </div>
              {bife.quality2 && (
                <div class="flex gap-2">
                  <p class="font-bold text-xs text-red-600/80">{bife.quality2}</p>
                </div>
              )}
              <p class="text-sm opacity-50">{bife.size}</p>
            </div>
          ))
        : (items as CorteTalla[]).map((item) => (
            <div class="justify-between flex flex-col text-sm leading-none items-center text-center gap-y-1">
              <p class="font-boldes">{item.name}</p>
              <p class="text-sm opacity-50">{item.size}</p>
            </div>
          ))
    }
  </div>
</div>
