---
import CardsComponent from "@/components/CardsComponent.astro";
import type { MenuItem } from "@/data/menuData";

export interface Props {
  id: string;
  items: MenuItem[];
  cols?: 3 | 4;
  extraClass?: string;
}

const { id, items, cols = 4, extraClass = "" } = Astro.props;

// Mapa de clases literales para que Tailwind JIT las detecte
const mdGridColsClass: Record<number, string> = {
  3: "md:grid-cols-3",
  4: "md:grid-cols-4",
};
const mdGridClass = mdGridColsClass[cols] ?? "md:grid-cols-4";

const baseClass = `w-full gap-y-16 md:grid ${mdGridClass} p-7 mb-24 text-white/85`;
const className = extraClass ? `${baseClass} ${extraClass}` : baseClass;
---

<div id={id} class={className}>
  {
    items.map((item) => (
      <CardsComponent
        src={item.src}
        name={item.name}
        description={item.description}
      />
    ))
  }
</div>
