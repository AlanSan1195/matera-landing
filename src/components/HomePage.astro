---
import HomeReserva from "@/components/HomeReserva.astro";
import LandingHeader from "@/components/LandingHeader.astro";
import Carta from "@/components/Carta.astro";
import Eventos from "@/components/Eventos.astro";
import Layout from "@/layouts/Layout.astro";
import SmokeEffect from "@/components/SmokeEffect.astro";
import Nosotros from "@/components/Nosotros.astro";
import { type Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
  title: string;
  description: string;
}

const { lang, title, description } = Astro.props;
---

<Layout title={title} description={description} lang={lang}>
  <LandingHeader />
  <main>
    <SmokeEffect />
    <HomeReserva lang={lang} />
    <Carta />
    <Eventos lang={lang} />
    <Nosotros lang={lang} />
  </main>
</Layout>
