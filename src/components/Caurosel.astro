---
import { useTranslations, type Lang } from "@/i18n/utils";

interface Props {
  id?: string;
  lang: Lang;
}

const { id, lang } = Astro.props;
const t = useTranslations(lang);

const slideImages = [
  {
    img: "/imagenes/seleccion.webp",
    title: t.carousel.slide1.title,
    subtitle: "",
    description: t.carousel.slide1.description,
  },
  {
    img: "/imagenes/champagne.webp",
    title: t.carousel.slide2.title,
    subtitle: t.carousel.slide2.subtitle,
    description: t.carousel.slide2.description,
    contacto: "Casamatera@grupolamatera.mx",
    ctaText: t.carousel.slide2.cta,
  },
  {
    img: "/imagenes/productosCalidad2.webp",
    title: t.carousel.slide3.title,
    subtitle: t.carousel.slide3.subtitle,
    description: t.carousel.slide3.description,
  },
  {
    img: "/imagenes/ambiente.webp",
    title: t.carousel.slide4.title,
    subtitle: t.carousel.slide4.subtitle,
    description: t.carousel.slide4.description,
  },
  {
    img: "/imagenes/panNuestro.webp",
    title: t.carousel.slide5.title,
    subtitle: "",
    description: t.carousel.slide5.description,
    href: "https://www.instagram.com/pannuestrogdl/?hl=es",
    ctaText: t.carousel.slide5.cta,
    id: "panNuestro",
  },
];
---

<div class="flex flex-wrap relative w-screen h-screen" id="carrusel">
  <div
    class="container max-w-[1950px] object-cover"
    id={id}
  >
    <div class="slider"></div>
  </div>
  <script define:vars={{ slideImages }}>
    (() => {
      // este slice fue logrador por Fernando Herrera,divulgador de la programacion solo fue adaptado responsivamente,  dejo el repositorio https://github.com/Klerith/js-slider-from-codetheword

      const createHtmlStructure = (sliderSelector, images) => {
        const parent = document.querySelector(sliderSelector);

        // Slides
        images.forEach((slideImg, index) => {
          const { img, title, description, contacto, href, id, subtitle, ctaText } =
            slideImg;
          const slideItem = `
      <div
        class="item "
        style="background-image: url('${img}')"
        data-attribute="${index}"
      >
        <div class="content   ">
          <div class="name font-boldes flex felx-row gap-x-2 "> <h3 class="opacity-85">${title}</h3> <span class ="text-red-900  ">${subtitle}</span> </div> 
          <div class="description w-[200px] md:w-[350px] lg:w-[500px] lg:text-lg opacity-100 ">${description}</div>
        ${
          contacto
            ? `<a href="mailto:Casamatera@grupolamatera.mx" class="text-white  border-2   border-[#B56C09] rounded-xl bg-red-900 w-[130px] scale-110 hover:75 text-xs font-bold p-1 lg:w-[155px] lg:scale-125 md:m-4 lg:text-xs xl:text-sm xl:w-[180px] flex items-center justify-center hover:scale-110 transition ">${ctaText || "Cotiza tu evento"}</a>`
            : ""
        }
        ${
          href
            ? `<a href="https://www.instagram.com/pannuestrogdl/?hl=es" target="_blank" rel="noopener noreferrer"  class="text-white  border-2   border-[#B56C09] rounded-xl bg-red-900/90 w-[130px] scale-110 hover:75 text-xs font-bold p-1 lg:w-[155px] lg:scale-125 md:m-4 lg:text-xs xl:text-sm xl:w-[180px] flex items-center justify-center hover:scale-110 transition ">${ctaText || "Ver más"}</a>`
            : ""
        }
        
        </div>
      </div>
      `;
          const divFragment = document
            .createRange()
            .createContextualFragment(slideItem);
          parent.appendChild(divFragment);
        });

        // Buttons prev y nexts
        const html = `
    <div class="buttons">
      <button class="prev text-white scale-150 border-2 m-4 md:m-8 border-[#B56C09] rounded-xl bg-red-900 lg:w-20 flex items-center justify-center hover:scale-125 transition  " aria-label="anterior"><svg  xmlns="http://www.w3.org/2000/svg"  width="24"  height="24"  viewBox="0 0 24 24"  fill="none"  stroke="currentColor"  stroke-width="2"  stroke-linecap="round"  stroke-linejoin="round"  class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-left"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M15 6l-6 6l6 6" /></svg></button>
      <button class="next text-white scale-150 border-2 m-4 md:m-8 border-[#B56C09]  rounded-xl bg-red-900 lg:w-20  flex items-center justify-center hover:scale-125 transition " aria-label="siguiente"> <svg  xmlns="http://www.w3.org/2000/svg"  width="24"  height="24"  viewBox="0 0 24 24"  fill="none"  stroke="currentColor"  stroke-width="2"  stroke-linecap="round"  stroke-linejoin="round"  class="icon icon-tabler icons-tabler-outline icon-tabler-chevron-right"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 6l6 6l-6 6" /></svg></button>
    </div>
    `;
        const fragment = document.createRange().createContextualFragment(html);
        parent.parentElement.appendChild(fragment);
      };

      // Initializations
      createHtmlStructure(".slider", slideImages);

      // References
      const $slider = document.querySelector(".slider");
      const $next = document.querySelector(".next");
      const $prev = document.querySelector(".prev");

      // Listeners
      $next.addEventListener("click", () => {
        const items = document.querySelectorAll(".item");
        $slider.appendChild(items[0]);
      });

      $prev.addEventListener("click", () => {
        const items = document.querySelectorAll(".item");
        $slider.prepend(items[items.length - 1]);
      });
    })();
  </script>
</div>
