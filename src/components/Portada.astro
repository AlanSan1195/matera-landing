---
const { color, subtitle, tagline, id } = Astro.props;
const textColor = `text-${color}`;
---

<section
  class="landing-section min-h-screen w-screen text-center overflow-hidden flex items-center"
  data-header-color={color}
  id={id}
>
  <div
    class="opacity-85 z-30 relative h-auto text-end m-2  w-[90%] md:w-[70%] lg:w-[65%] xl:w-[60%] max-w-[1200px] flex flex-col flex-wrap ml-auto text-prett "
  >
    <header class="lg:p-2">
      <h1
        class={`${textColor} font-boldes mr-2 mt-4 lg:mr-4 pt-16 md:pt-20 lg:pt-28 xl:pt-48 text-7xl lg:text-7xl xl:text-8xl leading-none text-opacity-95 text-pretty`}
      >
        <span class="text-red-700 text-[1.1em] font-bold">"</span>{tagline ?? "Buenos Amigos, Buenos Vinos, Buenos Aires."}<span
          class="text-red-700 text-[1.1em] font-bold">"</span
        >
      </h1>
      <p
        class={`${textColor} opacity-85 mr-2 ml-5 text-pretty lg:mr-4 text-md md:text-lg xl:text-xl font-semibold md:font-medium mt-3`}
      >
        {subtitle}
      </p>
    </header>

    <footer
      class="py-6 flex flex-col flex-grow justify-end mr-auto ml-auto md:mr-14"
    >
      <slot name="footer" />
    </footer>
  </div>

  <div class="absolute top-0 bottom-0 h-full w-full z-10 hidden md:block">
    <slot name="background" />
  </div>
</section>

