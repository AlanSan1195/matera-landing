---
export interface Props {
  variant?: "main" | "compact";
  class?: string;
}

const { variant = "main", class: className } = Astro.props;

const baseClasses = "transition-opacity duration-300 hover:cursor-pointer";

const variantClasses: Record<string, string> = {
  main: "h-16 w-12 -ml-6 md:h-36 md:w-16 md:mt-24 md:ml-12 lg:h-[200px] lg:w-44 lg:ml-1 lg:top-4 top-3 fixed",
  compact: "h-10 w-10 md:h-[54px] md:w-[54px]",
};

const classes = [baseClasses, variantClasses[variant], className]
  .filter(Boolean)
  .join(" ");

const altText =
  variant === "main"
    ? "La Matera — Ir al inicio"
    : "La Matera";
---

{
  variant === "main" ? (
    <a href="#home" aria-label="Ir al inicio">
      <img
        class={classes}
        src="/imagenes/logotipo.svg"
        alt={altText}
        width="34"
        height="82"
        loading="eager"
        decoding="async"
      />
    </a>
  ) : (
    <img
      class={classes}
      src="/imagenes/logotipo.svg"
      alt={altText}
      width="34"
      height="82"
      loading="eager"
      decoding="async"
    />
  )
}
