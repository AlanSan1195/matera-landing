---
import Logo from "./Logo.astro";
import LangSelector from "./LangSelector.astro";
import UserIcon from "./icons/User.astro";
import { SignedIn, SignedOut, UserButton } from "@clerk/astro/components";
import { getLangFromUrl, useTranslations, type Lang } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
---

<header
  id="landing-header"
  class="py-4 md:py-3 lg:py-3 px-4 sm:px-6 md:px-10 flex items-center fixed top-0 left-0 right-0 w-full max-w-full box-border justify-between z-[70] text-white/65 bg-black/25 rounded-b-3xl"
>
  <div id="logo1" class="flex shrink-0 w-10 md:flex-grow md:basis-0 md:w-auto md:pointer-events-none">
    <Logo variant="main" />
  </div>
  <div id="logo2" class="opacity-0 md:flex absolute">
    <Logo variant="compact" />
  </div>

  <nav class="hidden md:block">
    <ul
      class="flex text-sm [&>li>a]:transition-colors [&>li>a]:duration-500 [&>li>a]:text-current [&>li>a]:font-boldes [&>li>a]:text-xl [&>li>a]:inline-block [&>li>a]:px-4 [&>li>a]:py-2"
    >
      <li>
        <a class="hover:text-red-800" href="#home" aria-label={t.nav.reserva}
          >{t.nav.reserva}</a
        >
      </li>
      <li>
        <a class="hover:text-red-800" href="#carta" aria-label={t.nav.carta}>{t.nav.carta}</a>
      </li>
      <li><a class="hover:text-red-800" href="#eventos">{t.nav.eventos}</a></li>
      <li>
        <a class="hover:text-red-800" href="#nosotros" aria-label={t.nav.nosotros}
          >{t.nav.nosotros}</a
        >
      </li>
      <SignedIn>
        <li>
          <a class="hover:text-red-800" href="/Dropbox" data-no-gate aria-label="Manual">Manual</a>
        </li>
      </SignedIn>
    </ul>
  </nav>

  <!-- Derecha: selector de idioma + auth + hamburguesa móvil -->
  <nav class="flex flex-grow justify-end basis-0 items-center gap-2 md:gap-3">
    <!-- Selector de idioma: visible siempre -->
    <LangSelector currentLang={lang} currentPath={currentPath} />

    <!-- Auth: icono login o UserButton -->
    <SignedOut>
      <a
        href="/Dropbox"
        aria-label="Iniciar sesión"
        class="flex items-center justify-center w-9 h-9 text-white/80 hover:text-white transition-colors"
      >
        <UserIcon class="w-6 h-6" />
      </a>
    </SignedOut>
    <SignedIn>
      <UserButton />
    </SignedIn>

    <!-- Botón hamburguesa móvil -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex items-center justify-center w-9 h-9 text-white/80 hover:text-white transition-colors"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Modal contraseña previa -->
  <div
    id="password-gate-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="password-gate-title"
    class="fixed inset-0 z-[100] bg-black/80 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
    aria-hidden="true"
  >
    <div class="bg-neutral-900 border border-red-900/40 rounded-2xl p-8 w-[90vw] max-w-sm flex flex-col items-center gap-5 shadow-2xl">
      <h2 id="password-gate-title" class="text-white font-boldes text-2xl text-center">Acceso solo a personal autorizado.</h2>
      <p class="text-white/60 text-sm text-center">Ingresá la contraseña para continuar</p>
      <div class="relative w-full">
        <label for="password-gate-input" class="sr-only">Contraseña de acceso</label>
        <input
          id="password-gate-input"
          type="password"
          placeholder="Contraseña"
          autocomplete="off"
          class="w-full rounded-lg bg-neutral-800 border border-white/10 text-white px-4 py-3 pr-11 text-sm focus:outline-none focus:border-red-700 transition-colors"
        />
        <button
          id="password-gate-toggle"
          type="button"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-white/50 hover:text-white transition-colors"
          aria-label="Mostrar contraseña"
        >
          <!-- Ojo abierto (visible por defecto) -->
          <svg id="icon-eye-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
            <circle cx="12" cy="12" r="3" />
          </svg>
          <!-- Ojo cerrado (oculto por defecto) -->
          <svg id="icon-eye-closed" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
            <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
            <path d="M1 1l22 22" />
            <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24" />
          </svg>
        </button>
      </div>
      <p id="password-gate-error" class="text-red-500 text-xs hidden">Contraseña incorrecta</p>
      <div class="flex gap-3 w-full">
        <button
          id="password-gate-cancel"
          class="flex-1 rounded-lg border border-white/10 text-white/70 py-2.5 text-sm hover:bg-white/5 transition-colors"
        >
          Cancelar
        </button>
        <button
          id="password-gate-submit"
          class="flex-1 rounded-lg bg-red-800 text-white py-2.5 text-sm hover:bg-red-700 transition-colors font-semibold"
        >
          Entrar
        </button>
      </div>
    </div>
  </div>

  <!-- Menú móvil (pantalla completa) -->
  <nav
    id="mobile-menu"
    class="fixed inset-0 top-0 z-[80] bg-black/95 backdrop-blur-md flex flex-col items-center justify-center gap-8 transition-all duration-300 opacity-0 pointer-events-none md:hidden"
    aria-hidden="true"
  >
    <button
      id="mobile-menu-close"
      class="absolute top-5 right-5 w-10 h-10 flex items-center justify-center text-white/80 hover:text-white transition-colors"
      aria-label="Cerrar menú"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>
    <ul class="flex flex-col items-center gap-6 text-center">
      <li>
        <a class="text-white/90 font-boldes text-2xl hover:text-red-700 transition-colors mobile-nav-link" href="#home">
          {t.nav.reserva}
        </a>
      </li>
      <li>
        <a class="text-white/90 font-boldes text-2xl hover:text-red-700 transition-colors mobile-nav-link" href="#carta">
          {t.nav.carta}
        </a>
      </li>
      <li>
        <a class="text-white/90 font-boldes text-2xl hover:text-red-700 transition-colors mobile-nav-link" href="#eventos">
          {t.nav.eventos}
        </a>
      </li>
      <li>
        <a class="text-white/90 font-boldes text-2xl hover:text-red-700 transition-colors mobile-nav-link" href="#nosotros">
          {t.nav.nosotros}
        </a>
      </li>
      <SignedIn>
        <li>
          <a class="text-white/90 font-boldes text-2xl hover:text-red-700 transition-colors mobile-nav-link" href="/Dropbox" data-no-gate>
            Manual
          </a>
        </li>
      </SignedIn>
    </ul>
  </nav>

  <script>
    // Menú móvil: abrir/cerrar
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileMenuClose = document.getElementById("mobile-menu-close");
    const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

    function openMobileMenu() {
      if (!mobileMenu || !mobileMenuBtn) return;
      mobileMenu.classList.remove("opacity-0", "pointer-events-none");
      mobileMenu.classList.add("opacity-100", "pointer-events-auto");
      mobileMenu.setAttribute("aria-hidden", "false");
      mobileMenuBtn.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    }

    function closeMobileMenu() {
      if (!mobileMenu || !mobileMenuBtn) return;
      mobileMenu.classList.remove("opacity-100", "pointer-events-auto");
      mobileMenu.classList.add("opacity-0", "pointer-events-none");
      mobileMenu.setAttribute("aria-hidden", "true");
      mobileMenuBtn.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }

    mobileMenuBtn?.addEventListener("click", openMobileMenu);
    mobileMenuClose?.addEventListener("click", closeMobileMenu);
    mobileNavLinks.forEach((link) => {
      link.addEventListener("click", closeMobileMenu);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMobileMenu();
    });
  </script>

  <script>
    // Gate de contraseña — validación server-side via /api/gate
    const gateModal = document.getElementById("password-gate-modal");
    const gateInput = document.getElementById("password-gate-input") as HTMLInputElement | null;
    const gateError = document.getElementById("password-gate-error");
    const gateCancel = document.getElementById("password-gate-cancel");
    const gateSubmit = document.getElementById("password-gate-submit");
    const gateToggle = document.getElementById("password-gate-toggle");
    const iconEyeOpen = document.getElementById("icon-eye-open");
    const iconEyeClosed = document.getElementById("icon-eye-closed");

    let pendingHref: string | null = null;
    let submitting = false;

    // Toggle visibilidad de contraseña
    gateToggle?.addEventListener("click", () => {
      if (!gateInput) return;
      const isPassword = gateInput.type === "password";
      gateInput.type = isPassword ? "text" : "password";
      iconEyeOpen?.classList.toggle("hidden", isPassword);
      iconEyeClosed?.classList.toggle("hidden", !isPassword);
      gateToggle.setAttribute("aria-label", isPassword ? "Ocultar contraseña" : "Mostrar contraseña");
    });

    function openGateModal(href: string) {
      pendingHref = href;
      if (!gateModal || !gateInput) return;
      gateInput.value = "";
      gateInput.type = "password";
      iconEyeOpen?.classList.remove("hidden");
      iconEyeClosed?.classList.add("hidden");
      gateToggle?.setAttribute("aria-label", "Mostrar contraseña");
      gateError?.classList.add("hidden");
      gateModal.classList.remove("opacity-0", "pointer-events-none");
      gateModal.classList.add("opacity-100", "pointer-events-auto");
      gateModal.setAttribute("aria-hidden", "false");
      setTimeout(() => gateInput.focus(), 100);
    }

    function closeGateModal() {
      if (!gateModal) return;
      gateModal.classList.remove("opacity-100", "pointer-events-auto");
      gateModal.classList.add("opacity-0", "pointer-events-none");
      gateModal.setAttribute("aria-hidden", "true");
      pendingHref = null;
    }

    async function attemptGateSubmit() {
      if (!gateInput || submitting) return;
      submitting = true;
      gateError?.classList.add("hidden");

      try {
        const res = await fetch("/api/gate", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ password: gateInput.value }),
        });

        if (res.ok) {
          const href = pendingHref;
          closeGateModal();
          if (href) window.location.href = href;
        } else {
          gateError?.classList.remove("hidden");
          gateInput.value = "";
          gateInput.focus();
        }
      } catch {
        gateError?.classList.remove("hidden");
      } finally {
        submitting = false;
      }
    }

    // Interceptar solo enlaces a /Dropbox que NO tengan data-no-gate (usuarios no logueados)
    const header = document.getElementById("landing-header");
    header?.querySelectorAll<HTMLAnchorElement>('a[href="/Dropbox"]:not([data-no-gate])').forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        openGateModal(link.href);
      });
    });

    gateCancel?.addEventListener("click", closeGateModal);
    gateSubmit?.addEventListener("click", () => attemptGateSubmit());

    gateInput?.addEventListener("keydown", (e) => {
      if (e.key === "Enter") attemptGateSubmit();
      if (e.key === "Escape") closeGateModal();
    });

    // Cerrar modal al hacer click fuera del card
    gateModal?.addEventListener("click", (e) => {
      if (e.target === gateModal) closeGateModal();
    });
  </script>

  <script>
    // Scroll unificado: logo swap + header background
    const logo1 = document.getElementById("logo1");
    const logo2 = document.getElementById("logo2");
    const header = document.getElementById("landing-header");

    let ticking = false;

    function onScroll() {
      if (ticking) return;
      ticking = true;

      requestAnimationFrame(() => {
        const scrolled = window.scrollY > 400;
        const isDesktop = window.innerWidth >= 768;

        // Logo swap (solo desktop)
        if (isDesktop && logo1 && logo2) {
          if (scrolled) {
            logo2.classList.remove("hidden");
            logo1.style.transition = "opacity 0.3s";
            logo1.style.opacity = "0";
            logo2.style.opacity = "1";
            logo2.style.transition = "opacity 0.3s";
          } else {
            logo1.style.opacity = "1";
            logo2.style.opacity = "0";
          }
        }

        // Header background
        if (header) {
          if (scrolled) {
            header.style.transition = "background-color .5s";
            header.style.borderBottom = isDesktop
              ? "1px ridge #7F1C1D"
              : "2px ridge #7F1C1D";
            header.style.backgroundColor = "black";
          } else {
            header.style.backgroundColor = "rgba(0, 0, 0, 0.30)";
            header.style.borderBottom = "none";
            header.style.backdropFilter = "none";
          }
        }

        ticking = false;
      });
    }

    document.addEventListener("scroll", onScroll, { passive: true });
  </script>
</header>
